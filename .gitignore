# ============================================================================
# research-consulting-team - 루트 .gitignore
# ⚠️ 이 스킬은 팀 내부 전용입니다. 자격증명·실행 로그가 외부로 새지 않도록
#    아래 항목은 절대 커밋되지 않습니다.
# ============================================================================

# --- 자격증명 (절대 커밋 금지) ---
.env
.env.*
!.env.example
secrets/.env
secrets/*.env
secrets/*.key
secrets/*.pem
secrets/*.json
secrets/*.token
secrets/credentials*

# --- learning log 실행 기록 (민감 데이터 포함 가능) ---
learning-log/runs/
!learning-log/runs/.gitkeep

# --- 캐시·임시 파일 ---
.cache/
.tmp/
*.tmp
*.bak
*.swp

# --- OS / 에디터 ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.iml

# --- 다운로드 자료 (라이선스 위반 방지) ---
downloads/
fetched-reports/
*.pdf.cache
